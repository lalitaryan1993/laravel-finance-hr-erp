APP_NAME="AI-FMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_fms
DB_USERNAME=root
DB_PASSWORD=

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_STORE=database
CACHE_PREFIX=ai_fms_

# ─── Queue ───────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ─── Broadcasting ────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ai-fms.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Filesystem ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o

# ─── AI Financial Assistant ──────────────────────────────────────────────────
AI_ENABLED=true
AI_FRAUD_DETECTION=true
AI_FORECASTING=true
AI_OCR_ENABLED=true

# ─── Security ────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
TWO_FACTOR_ENABLED=true
IP_RESTRICTION_ENABLED=false
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

# ─── Multi-tenant ────────────────────────────────────────────────────────────
MULTI_TENANT=true
TENANT_DRIVER=company

# ─── Financial ───────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=INR
DEFAULT_CURRENCY_SYMBOL=₹
DEFAULT_DATE_FORMAT=d/m/Y
FISCAL_YEAR_START=04
GST_ENABLED=true
TDS_ENABLED=true

# ─── Notifications ───────────────────────────────────────────────────────────
SMS_PROVIDER=twilio
SMS_FROM=
TWILIO_SID=
TWILIO_TOKEN=
WHATSAPP_API_KEY=

# ─── Feature Flags ───────────────────────────────────────────────────────────
FEATURE_PAYROLL=true
FEATURE_ASSETS=true
FEATURE_AI_ASSISTANT=true
FEATURE_INSTALLER=true
FEATURE_SUBSCRIPTION=true

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
